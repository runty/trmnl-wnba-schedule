<div class="layout layout--col">
  {% if calendars != blank %}
    {% assign cal = calendars[0] %}
    <div class="flex gap--medium" style="width: 100%;">

      <!-- Calendar Grid -->
      <div style="flex: 1;">
        <div class="flex" style="justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
          <span class="title">{{ cal.month_name }} {{ cal.year }}</span>
          <span class="label label--small">
            <span class="record-pill">{{ team.record }}</span>
          </span>
        </div>
        <div class="cal-grid">
          <div class="cal-header label label--small">S</div>
          <div class="cal-header label label--small">M</div>
          <div class="cal-header label label--small">T</div>
          <div class="cal-header label label--small">W</div>
          <div class="cal-header label label--small">T</div>
          <div class="cal-header label label--small">F</div>
          <div class="cal-header label label--small">S</div>
          {% for week in cal.weeks %}
            {% for d in week %}
              {% if d.day == 0 %}
                <div class="cal-day cal-day--empty">&nbsp;</div>
              {% elsif d.has_game and d.completed and d.result == "W" %}
                <div class="cal-day cal-day--win">
                  {{ d.day }}
                  <span class="cal-detail">{{ d.opp_abbr }} {{ d.score_display }}</span>
                </div>
              {% elsif d.has_game and d.completed %}
                <div class="cal-day cal-day--loss">
                  {{ d.day }}
                  <span class="cal-detail">{{ d.opp_abbr }} {{ d.score_display }}</span>
                </div>
              {% elsif d.has_game %}
                <div class="cal-day cal-day--upcoming">
                  {{ d.day }}
                  <span class="cal-detail">{{ d.opp_abbr }}</span>
                </div>
              {% else %}
                <div class="cal-day">
                  <span class="label label--small">{{ d.day }}</span>
                </div>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </div>
      </div>

      <!-- Upcoming Games List -->
      <div style="flex: 1; padding-left: 12px; border-left: 2px solid black;">
        <span class="title title--small" style="margin-bottom: 6px; display: block;">Upcoming</span>

        <table style="width: 100%; border-collapse: collapse;">
          {% for game in upcoming limit: 5 %}
            {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
            {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
            {% assign parts = game.date_short | split: " - " %}
            {% if forloop.first %}
              <tr style="border-bottom: 1px solid #ccc;">
                <td style="padding: 5px 6px 2px 0; white-space: nowrap; vertical-align: middle; width: 36px;">
                  <span class="label" style="font-weight: bold;">{{ parts[0] }}</span>
                </td>
                <td style="padding: 5px 4px 2px; vertical-align: middle; width: 28px;">
                  <img src="{{ game.opp_logo }}" width="28" height="28" style="display: block; object-fit: contain;" />
                </td>
                <td style="padding: 5px 4px 2px; vertical-align: middle;">
                  <span class="label" style="font-weight: bold;">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_abbr }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
                </td>
                <td style="padding: 5px 0 2px 4px; white-space: nowrap; vertical-align: middle; text-align: right;">
                  <span class="label label--small">{{ parts[1] }}</span>
                </td>
              </tr>
              <tr>
                <td colspan="4" style="padding: 0 0 2px 0; text-align: right;">
                  <span class="description">{{ game.venue }}, {{ game.city }}</span>
                </td>
              </tr>
              {% if next_game.preview != blank %}
              <tr style="border-bottom: 2px solid black;">
                <td colspan="4" style="padding: 0 0 6px 0;">
                  <span class="description">{{ next_game.preview }}</span>
                </td>
              </tr>
              {% endif %}
            {% else %}
              <tr style="border-bottom: 1px solid #ccc;">
                <td style="padding: 4px 6px 4px 0; white-space: nowrap; vertical-align: middle; width: 36px;">
                  <span class="label label--small">{{ parts[0] }}</span>
                </td>
                <td style="padding: 4px 4px; vertical-align: middle; width: 22px;">
                  <img src="{{ game.opp_logo }}" width="22" height="22" style="display: block; object-fit: contain;" />
                </td>
                <td style="padding: 4px 4px; vertical-align: middle;">
                  <span class="label label--small">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_abbr }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
                </td>
                <td style="padding: 4px 0 4px 4px; white-space: nowrap; vertical-align: middle; text-align: right;">
                  <span class="label label--small">{{ parts[1] }}</span>
                </td>
              </tr>
            {% endif %}
          {% endfor %}
        </table>
      </div>
    </div>

  {% else %}
    <!-- Fallback list view -->
    <div style="width: 100%;">
      <div class="flex" style="justify-content: space-between; margin-bottom: 8px;">
        <span class="title">{{ team.name }} Schedule</span>
        <span class="record-pill label">{{ team.record }}</span>
      </div>
      <table style="width: 100%; border-collapse: collapse;">
        {% for game in upcoming limit: 6 %}
          {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
          {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
          {% assign parts = game.date_short | split: " - " %}
          <tr style="border-bottom: 1px solid #ccc;">
            <td style="padding: 5px 6px 5px 0; white-space: nowrap; vertical-align: middle; width: 36px;">
              <span class="label">{{ parts[0] }}</span>
            </td>
            <td style="padding: 5px 4px; vertical-align: middle; width: 28px;">
              <img src="{{ game.opp_logo }}" width="28" height="28" style="display: block; object-fit: contain;" />
            </td>
            <td style="padding: 5px 4px; vertical-align: middle;">
              <span class="label">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opponent }}</span>
            </td>
            <td style="padding: 5px 0 5px 4px; white-space: nowrap; vertical-align: middle; text-align: right;">
              <span class="label label--small">{{ parts[1] }}</span>
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ trmnl.plugin_settings.instance_name }}</span>
</div>
