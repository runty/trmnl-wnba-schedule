<div class="layout layout--col">
  {% if calendars.size > 0 %}
    {% assign cal = calendars[0] %}
    <div class="flex gap--medium" style="width: 100%;">

      <!-- Calendar Grid -->
      <div style="flex: 1;">
        <div class="flex" style="justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
          <span class="title">{{ cal.month_name }} {{ cal.year }}</span>
          <span class="label label--small">
            <span class="record-pill">{{ team.record }}</span>
          </span>
        </div>
        <div class="cal-grid">
          <div class="cal-header label label--small">S</div>
          <div class="cal-header label label--small">M</div>
          <div class="cal-header label label--small">T</div>
          <div class="cal-header label label--small">W</div>
          <div class="cal-header label label--small">T</div>
          <div class="cal-header label label--small">F</div>
          <div class="cal-header label label--small">S</div>
          {% for week in cal.weeks %}
            {% for d in week %}
              {% if d.day == 0 %}
                <div class="cal-day cal-day--empty">&nbsp;</div>
              {% elsif d.has_game %}
                <div class="cal-day cal-day--game">
                  {{ d.day }}
                  <span class="cal-opp">{{ d.opp_abbr }}</span>
                </div>
              {% else %}
                <div class="cal-day">
                  <span class="label label--small">{{ d.day }}</span>
                </div>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </div>
      </div>

      <!-- Upcoming Games List -->
      <div style="flex: 1; padding-left: 12px; border-left: 2px solid black;">
        <span class="title title--small" style="margin-bottom: 4px; display: block;">Upcoming</span>
        {% for game in upcoming limit: 8 %}
          {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
          {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
          <div class="game-row">
            <span class="ha-badge {% if game.is_home %}ha-badge--home{% endif %}">{% if game.is_home %}H{% else %}A{% endif %}</span>
            <span class="label label--small" style="min-width: 56px;">{{ game.date_short }}</span>
            <span class="label label--small" style="flex: 1;" data-clamp="1">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_abbr }}</span>
          </div>
        {% endfor %}
        {% if games_remaining > 8 %}
          <span class="description" style="margin-top: 4px; display: block;">+ {{ games_remaining | minus: 8 }} more games</span>
        {% endif %}
      </div>
    </div>

  {% else %}
    <!-- No calendar data - show list view -->
    <div style="width: 100%;">
      <div class="flex" style="justify-content: space-between; margin-bottom: 8px;">
        <span class="title">{{ team.name }} Schedule</span>
        <span class="record-pill label">{{ team.record }}</span>
      </div>
      {% for game in upcoming limit: 10 %}
        {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
        {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
        <div class="game-row">
          <span class="ha-badge {% if game.is_home %}ha-badge--home{% endif %}">{% if game.is_home %}H{% else %}A{% endif %}</span>
          <span class="label" style="min-width: 80px;">{{ game.date_short }}</span>
          <span class="label" style="flex: 1;">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opponent }}</span>
          <span class="label label--small">{{ game.venue }}</span>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ trmnl.plugin_settings.instance_name }}</span>
</div>
