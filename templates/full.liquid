<div class="layout layout--col gap--distribute">
  {% if calendars != blank %}
    {% assign cal = calendars[0] %}
    <div class="flex gap--medium w--full flex--center-y grow">

      <!-- Calendar Grid -->
      <div class="stretch-x">
        <div class="flex flex--between flex--center-y mb--2">
          <span class="title flex flex--center-y gap--small">
            <img src="{{ team.logo }}" width="36" height="36" class="image--contain" />
            {{ cal.month_name }} {{ cal.year }}
          </span>
          <span class="label label--small">
            <span class="record-pill px--2 py--1">{{ team.record }}</span>
          </span>
        </div>
        <div class="grid grid--cols-7 gap--[2px] text--center">
          <div class="label label--small p--1 border-b-2 text--center">S</div>
          <div class="label label--small p--1 border-b-2 text--center">M</div>
          <div class="label label--small p--1 border-b-2 text--center">T</div>
          <div class="label label--small p--1 border-b-2 text--center">W</div>
          <div class="label label--small p--1 border-b-2 text--center">T</div>
          <div class="label label--small p--1 border-b-2 text--center">F</div>
          <div class="label label--small p--1 border-b-2 text--center">S</div>
          {% for week in cal.weeks %}
            {% for d in week %}
              {% if d.day == 0 %}
                <div class="cal-cell cal-day--empty">&nbsp;</div>
              {% elsif d.has_game and d.completed and d.result == "W" %}
                <div class="cal-cell bg--black text--white p--1 text--center">
                  {{ d.day }}
                  <span class="cal-detail label label--small">{{ d.opp_abbr }} {{ d.score_display }}</span>
                </div>
              {% elsif d.has_game and d.completed %}
                <div class="cal-cell bg--error text--white p--1 text--center">
                  {{ d.day }}
                  <span class="cal-detail label label--small">{{ d.opp_abbr }} {{ d.score_display }}</span>
                </div>
              {% elsif d.has_game %}
                <div class="cal-cell bg--black text--white p--1 text--center">
                  {{ d.day }}
                  <span class="cal-detail label label--small">{{ d.opp_abbr }}</span>
                </div>
              {% else %}
                <div class="cal-cell p--1 text--center">
                  <span class="label label--small">{{ d.day }}</span>
                </div>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </div>
      </div>

      <!-- Upcoming Games List -->
      <div class="stretch-x pl--3 border-l-2">
        <div class="title title--small mb--2 bold">Upcoming</div>

        <table class="tbl">
          {% assign shown = 0 %}
          {% for game in upcoming %}
            {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
            {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
            {% if shown >= 5 %}{% break %}{% endif %}
            {% assign parts = game.date_short | split: " - " %}
            {% if shown == 0 %}
              <tr>
                <td class="td-date py--1 pr--2">
                  <span class="label bold">{{ parts[0] }}</span>
                </td>
                <td class="td-logo py--1 px--1">
                  <img src="{{ game.opp_logo }}" width="28" height="28" class="image--contain" />
                </td>
                <td class="py--1 px--1">
                  <span class="label bold">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_short }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
                </td>
                <td class="nowrap py--1 pl--1 text--right">
                  <span class="label label--small">{{ parts[1] }}</span>
                </td>
              </tr>
              <tr>
                <td colspan="4" class="text--right pb--1">
                  <span class="description">{{ game.venue }}, {{ game.city }}</span>
                </td>
              </tr>
              {% if next_game.preview != blank %}
              <tr>
                <td colspan="4" class="text--right pb--1">
                  <span class="label label--small">{{ next_game.preview }}</span>
                </td>
              </tr>
              {% endif %}
              <tr>
                <td colspan="4" class="border-b-2"></td>
              </tr>
            {% else %}
              <tr class="border-b-1">
                <td class="td-date py--1 pr--2">
                  <span class="label label--small">{{ parts[0] }}</span>
                </td>
                <td class="td-logo-sm py--1 px--1">
                  <img src="{{ game.opp_logo }}" width="22" height="22" class="image--contain" />
                </td>
                <td class="py--1 px--1">
                  <span class="label label--small">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_abbr }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
                </td>
                <td class="nowrap py--1 pl--1 text--right">
                  <span class="label label--small">{{ parts[1] }}</span>
                </td>
              </tr>
            {% endif %}
            {% assign shown = shown | plus: 1 %}
          {% endfor %}
        </table>
      </div>
    </div>

  {% else %}
    <!-- Fallback list view -->
    <div class="w--full">
      <div class="flex flex--between mb--2">
        <span class="title">{{ team.name }} Schedule</span>
        <span class="record-pill label px--2 py--1">{{ team.record }}</span>
      </div>
      <table class="tbl">
        {% for game in upcoming limit: 6 %}
          {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
          {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
          {% assign parts = game.date_short | split: " - " %}
          <tr class="border-b-1">
            <td class="td-date py--1 pr--2">
              <span class="label">{{ parts[0] }}</span>
            </td>
            <td class="td-logo py--1 px--1">
              <img src="{{ game.opp_logo }}" width="28" height="28" class="image--contain" />
            </td>
            <td class="py--1 px--1">
              <span class="label">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opponent }}</span>
            </td>
            <td class="nowrap py--1 pl--1 text--right">
              <span class="label label--small">{{ parts[1] }}</span>
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% endif %}

  {% if injuries.size > 0 %}
    <div class="w--full pt--1 border-t-1">
      <span class="label label--small">🏥 {% for inj in injuries %}{{ inj.name }} ({{ inj.position }}, {{ inj.status }}){% unless forloop.last %} · {% endunless %}{% endfor %}</span>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ trmnl.plugin_settings.instance_name }}</span>
</div>
