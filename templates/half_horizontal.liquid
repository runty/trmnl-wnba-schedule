<div class="layout layout--row flex--center-y">
  <div class="stretch-x">
    <table class="tbl">
      {% assign shown = 0 %}
      {% for game in upcoming %}
        {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
        {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
        {% if shown >= 4 %}{% break %}{% endif %}
        {% assign parts = game.date_short | split: " - " %}
        <tr class="border-b-1">
          <td class="td-date py--1 pr--2">
            <span class="label">{{ parts[0] }}</span>
          </td>
          <td class="td-logo-sm py--1 px--1">
            <img src="{{ game.opp_logo }}" width="22" height="22" class="image--contain" />
          </td>
          <td class="py--1 px--1">
            <span class="label">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_short }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
          </td>
          <td class="nowrap py--1 pl--1 text--right">
            <span class="label label--small">{{ parts[1] }}</span>
          </td>
        </tr>
        {% assign shown = shown | plus: 1 %}
      {% endfor %}
    </table>
  </div>

  <div class="flex flex--col flex--center-x gap--small pl--3 no-shrink w--48">
    <img src="{{ team.logo }}" width="80" height="80" class="image--contain" />
    {% if injuries.size > 0 %}
      <span class="label label--small text--center w--44 wrap">🏥 {% for inj in injuries %}{{ inj.name }}{% unless forloop.last %}, {% endunless %}{% endfor %}</span>
    {% endif %}
  </div>
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ team.record }}</span>
</div>
