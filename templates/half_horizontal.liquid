<div class="layout layout--row" style="align-items: center;">
  <div style="flex: 1;">
    <table style="width: 100%; border-collapse: collapse;">
      {% assign shown = 0 %}
      {% for game in upcoming %}
        {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
        {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
        {% if shown >= 4 %}{% break %}{% endif %}
        {% assign parts = game.date_short | split: " - " %}
        <tr style="border-bottom: 1px solid #ccc;">
          <td style="padding: 4px 6px 4px 0; white-space: nowrap; vertical-align: middle; width: 36px;">
            <span class="label">{{ parts[0] }}</span>
          </td>
          <td style="padding: 4px 4px; vertical-align: middle; width: 22px;">
            <img src="{{ game.opp_logo }}" width="22" height="22" style="display: block; object-fit: contain;" />
          </td>
          <td style="padding: 4px 4px; vertical-align: middle;">
            <span class="label">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_short }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
          </td>
          <td style="padding: 4px 0 4px 4px; white-space: nowrap; vertical-align: middle; text-align: right;">
            <span class="label label--small">{{ parts[1] }}</span>
          </td>
        </tr>
        {% assign shown = shown | plus: 1 %}
      {% endfor %}
    </table>
  </div>

  <div style="display: flex; flex-direction: column; align-items: center; padding-left: 12px; gap: 6px; flex-shrink: 0; width: 200px;">
    <img src="{{ team.logo }}" width="80" height="80" style="object-fit: contain;" />
    {% if injuries.size > 0 %}
      <span class="description" style="font-size: 12px; text-align: center; max-width: 180px; word-wrap: break-word;">🏥 {% for inj in injuries %}{{ inj.name }}{% unless forloop.last %}, {% endunless %}{% endfor %}</span>
    {% endif %}
  </div>
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ team.record }}</span>
</div>
