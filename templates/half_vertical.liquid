<div class="layout layout--col gap--distribute flex--center-x">
  <img src="{{ team.logo }}" width="60" height="60" class="image--contain mb--2" />

  <table class="tbl">
    {% assign shown = 0 %}
    {% for game in upcoming %}
      {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
      {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
      {% if shown >= 6 %}{% break %}{% endif %}
      {% assign parts = game.date_short | split: " - " %}
      {% if shown == 0 %}
        <tr>
          <td class="td-date-sm py--1 pr--1">
            <span class="label label--small bold">{{ parts[0] }}</span>
          </td>
          <td class="td-logo-xs py--1 px--1">
            <img src="{{ game.opp_logo }}" width="18" height="18" class="image--contain" />
          </td>
          <td class="py--1 px--1">
            <span class="label label--small bold">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_short }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
          </td>
          <td class="nowrap py--1 pl--1 text--right">
            <span class="label">{{ parts[1] }}</span>
          </td>
        </tr>
        <tr>
          <td colspan="4" class="text--right pb--1">
            <span class="description">{{ game.venue }}, {{ game.city }}</span>
          </td>
        </tr>
        {% if next_game.preview != blank %}
        <tr>
          <td colspan="4" class="text--right pb--1">
            <span class="description">{{ next_game.preview }}</span>
          </td>
        </tr>
        {% endif %}
        <tr>
          <td colspan="4" class="border-b-2"></td>
        </tr>
      {% else %}
        <tr class="border-b-1">
          <td class="td-date-sm py--1 pr--1">
            <span class="label label--small">{{ parts[0] }}</span>
          </td>
          <td class="td-logo-xs py--1 px--1">
            <img src="{{ game.opp_logo }}" width="18" height="18" class="image--contain" />
          </td>
          <td class="py--1 px--1">
            <span class="label label--small">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_abbr }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
          </td>
          <td class="nowrap py--1 pl--1 text--right">
            <span class="label">{{ parts[1] }}</span>
          </td>
        </tr>
      {% endif %}
      {% assign shown = shown | plus: 1 %}
    {% endfor %}
  </table>

  {% if injuries.size > 0 %}
    <div class="w--full pt--1 border-t-1">
      <span class="description">🏥 {% for inj in injuries %}{{ inj.name }}{% unless forloop.last %}, {% endunless %}{% endfor %}</span>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ team.record }}</span>
</div>
