<div class="layout layout--col" style="justify-content: space-between; align-items: center;">
  <img src="{{ team.logo }}" width="60" height="60" style="object-fit: contain; margin-bottom: 6px;" />

  <table style="width: 100%; border-collapse: collapse;">
    {% assign shown = 0 %}
    {% for game in upcoming %}
      {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
      {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
      {% if shown >= 6 %}{% break %}{% endif %}
      {% assign parts = game.date_short | split: " - " %}
      <tr style="border-bottom: 1px solid #ccc;">
        <td style="padding: 3px 4px 3px 0; white-space: nowrap; vertical-align: middle; width: 30px;">
          <span class="label label--small">{{ parts[0] }}</span>
        </td>
        <td style="padding: 3px 3px; vertical-align: middle; width: 18px;">
          <img src="{{ game.opp_logo }}" width="18" height="18" style="display: block; object-fit: contain;" />
        </td>
        <td style="padding: 3px 3px; vertical-align: middle;">
          <span class="label label--small">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_abbr }}{% if game.opp_record != blank %} ({{ game.opp_record }}){% endif %}</span>
        </td>
        <td style="padding: 3px 0 3px 3px; white-space: nowrap; vertical-align: middle; text-align: right;">
          <span class="label label--small" style="font-size: 10px;">{{ parts[1] }}</span>
        </td>
      </tr>
      {% assign shown = shown | plus: 1 %}
    {% endfor %}
  </table>

  {% if injuries.size > 0 %}
    <div style="width: 100%; padding-top: 4px; border-top: 1px solid #ccc;">
      <span class="description" style="font-size: 10px;">🏥 {% for inj in injuries %}{{ inj.name }}{% unless forloop.last %}, {% endunless %}{% endfor %}</span>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ team.record }}</span>
</div>
