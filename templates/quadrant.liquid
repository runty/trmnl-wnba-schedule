<div class="layout layout--col">
  <table style="width: 100%; border-collapse: collapse;">
    {% assign shown = 0 %}
    {% for game in upcoming %}
      {% if filter == "Home Only" and game.home_away != "home" %}{% continue %}{% endif %}
      {% if filter == "Away Only" and game.home_away != "away" %}{% continue %}{% endif %}
      {% if shown >= 4 %}{% break %}{% endif %}
      {% assign parts = game.date_short | split: " - " %}
      <tr style="border-bottom: 1px solid #ccc;">
        <td style="padding: 4px 4px 4px 0; white-space: nowrap; vertical-align: middle; width: 30px;">
          <span class="label label--small">{{ parts[0] }}</span>
        </td>
        <td style="padding: 4px 3px; vertical-align: middle; width: 24px;">
          <img src="{{ game.opp_logo }}" width="24" height="24" style="display: block; object-fit: contain;" />
        </td>
        <td style="padding: 4px 3px; vertical-align: middle;">
          <span class="label label--small">{% if game.is_home %}vs{% else %}@{% endif %} {{ game.opp_abbr }}{% if game.opp_record != blank %} <span style="font-size: 12px;">({{ game.opp_record }})</span>{% endif %}</span>
        </td>
        <td style="padding: 4px 0 4px 3px; white-space: nowrap; vertical-align: middle; text-align: right;">
          <span class="label label--small">{{ parts[1] }}</span>
        </td>
      </tr>
      {% assign shown = shown | plus: 1 %}
    {% endfor %}
  </table>
</div>

<div class="title_bar">
  <img class="image" src="{{ team.logo }}" />
  <span class="title">{{ team.name }}</span>
  <span class="instance">{{ team.record }}</span>
</div>
