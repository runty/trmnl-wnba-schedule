<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" />
<style>
  *, .title, .value, .label, .description, .instance, .index, span, td, th, div {
    font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif !important;
  }
  .cal-grid { grid-template-columns: repeat(7, 1fr); }
  .cal-header { border-bottom: 2px solid black; }
  .cal-cell { min-height: 38px; overflow: hidden; }
  .cal-day--empty { opacity: 0; }
  .cal-day--upcoming { background: black; color: white; }
  .cal-day--win { background: black; color: white; }
  .cal-day--loss { background: #cc0000; color: white; }
  .cal-detail { line-height: 1.1; white-space: nowrap; overflow: hidden; }
  .border-b-2 { border-bottom: 2px solid black; }
  .border-b-1 { border-bottom: 1px solid #ccc; }
  .border-t-1 { border-top: 1px solid #ccc; }
  .border-l-2 { border-left: 2px solid black; }
  .record-pill { border: 1px solid black; }
  .tbl { width: 100%; border-collapse: collapse; }
  .tbl td { vertical-align: middle; }
  .td-date { width: 36px; white-space: nowrap; }
  .td-date-sm { width: 30px; white-space: nowrap; }
  .td-logo { width: 28px; }
  .td-logo-sm { width: 22px; }
  .td-logo-md { width: 24px; }
  .td-logo-xs { width: 18px; }
  .wrap { word-wrap: break-word; }
  .bold { font-weight: bold; }
</style>

{% assign filter = trmnl.plugin_settings.custom_fields_values.game_filter | default: "All Games" %}
